# Copie este arquivo para .env e preencha os valores reais.
# .env NUNCA deve ser commitado (veja .gitignore).

# Supabase — valores públicos, ok expor no client bundle
VITE_SUPABASE_PROJECT_ID="<seu-project-ref>"
VITE_SUPABASE_URL="https://<seu-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-key-publica>"

# Dev-only: se "true", libera acesso subscriber em sandboxes não-locais.
# NUNCA setar em produção. Default: false.
VITE_ENABLE_PREVIEW_BYPASS="false"
